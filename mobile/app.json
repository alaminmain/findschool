{
  "expo": {
    "name": "Find School",
    "slug": "find-school",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0E7C3A"
    },
    "scheme": "findschool",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*",
      "assets/db/*"
    ],
    "privacy": "public",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "bd.findschool.app"
    },
    "android": {
      "package": "bd.findschool.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0E7C3A"
      },
      "permissions": [],
      "versionCode": 2
    },
    "plugins": [
      "expo-router",
      [
        "expo-sqlite",
        {
          "useSQLCipher": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "find-school-bd",
          "project": "mobile"
        }
      ]
    ],
    "extra": {
      "sentryDsn": "",
      "enableSentry": false,
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1130ec74-99cd-4123-8f3d-c6c2257b6cf2"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "alamindev01"
  }
}
